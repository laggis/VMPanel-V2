# ============================================================
# VM Control Panel - Environment Configuration
# ============================================================
# Rename this file to .env and fill in your values.
# ============================================================

DATABASE_URL=mysql+pymysql://vm_user:vm_password@localhost:3306/vm_control
SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30

VMRUN_PATH=C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe
TEMPLATE_VM_PATH=C:\Virtual Machines\Templates\Master-Windows.vmx
TEMPLATE_SNAPSHOT_NAME=Base-v2
VM_STORAGE_PATH=C:\Virtual Machines

BASE_SNAPSHOT_USER=Administrator
BASE_SNAPSHOT_PASSWORD=Kossa123

DEFAULT_GATEWAY=192.168.119.2
DEFAULT_SUBNET_MASK=255.255.255.0

DISCORD_WEBHOOK_URL=
